{
    "assist": {
        "actions": {
            "source": {
                "organizeImports": "off"
            }
        }
    },
    "linter": {
        "enabled": false,
        "rules": {
            "suspicious": {
                "noDebugger": "off"
            },
            "style": {
                "noShoutyConstants": "warn",
                "useNamingConvention": "error",
                "noNonNullAssertion": "off"
            }
        }
    },
    "formatter": {
        "enabled": false,
        "formatWithErrors": false,
        "attributePosition": "auto",
        "indentStyle": "tab",
        "indentWidth": 2,
        "lineWidth": 80,
        "lineEnding": "lf"
    },
    "files": {
        "ignoreUnknown": true,
        "includes": [
            "**/*.ts",
            "**/*.tsx"
        ]
    }
}